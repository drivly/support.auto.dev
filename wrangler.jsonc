{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"account_id": "b6641681fe423910342b9ffa1364c76d",
	"name": "support-auto-dev",
	"main": "src/index.ts",
	"compatibility_date": "2024-11-06",
	"compatibility_flags": [
		"nodejs_compat"
	],
	// Secrets (set via `wrangler secret put`): AUTO_DEV_API_KEY, SLACK_WEBHOOK_URL
	"vars": {
		"AUTO_DEV_API_URL": "https://api.auto.dev"
	},
	"kv_namespaces": [
		{
			"binding": "SUPPORT_KV",
			"id": "9ba3f71e4f9f422eb1c52c0c9534d5c1"
		}
	]
}